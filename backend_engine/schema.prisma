generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

generator client_python {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  interface            = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String?            @unique
  emailVerified     DateTime?
  image             String?
  role              String             @default("viewer")
  last_login        DateTime?
  accounts          Account[]
  clientAccesses    ClientAccess[]
  comments          Comment[]
  matterMembers     MatterMember[]
  notifications     Notification[]
  organizationUsers OrganizationUser[]
  provisionEdits    ProvisionEdit[]
  sessions          Session[]
  assignedTasks     Task[]
  TaskInstance      TaskInstance[]
  documents         Document[]
}

model Notification {
  id           String        @id @default(cuid())
  user_id      String
  org_id       String?
  title        String
  message      String
  type         String
  link         String?
  read         Boolean       @default(false)
  created_at   DateTime      @default(now())
  organization Organization? @relation(fields: [org_id], references: [id])
  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id            String             @id @default(cuid())
  name          String
  plan          String             @default("Free")
  settings      Json?
  created_at    DateTime           @default(now())
  matters       Matter[]
  notifications Notification[]
  users         OrganizationUser[]
  provisions    Provision[]
  auditLogs     AuditLog[]
  subscription  Subscription?
}

model OrganizationUser {
  id           String       @id @default(cuid())
  org_id       String
  user_id      String
  role         String       @default("Member")
  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String       @id @default(cuid())
  org_id             String       @unique
  stripe_cust_id     String?
  plan_tier          String       @default("Free")
  status             String       @default("Active")
  current_period_end DateTime?
  organization       Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
}

model ClientAccess {
  id         String  @id @default(cuid())
  user_id    String
  matter_id  String?
  company_id String?
  role       String  @default("ClientViewer")
  entity     Entity? @relation(fields: [company_id], references: [id], onDelete: Cascade)
  matter     Matter? @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Provision {
  id               String              @id @default(cuid())
  org_id           String?
  code             String
  chapter          String
  chapter_name     String
  section          String
  sub_section      String
  title            String
  summary          String
  full_text        String
  impact           String
  rule_authority   String
  change_tags      String[]
  workflow_tags    String[]
  penalty_old      String?
  penalty_new      String?
  notes            String?
  assignee         String?
  due_date         DateTime?
  verified         Boolean             @default(false)
  pinned           Boolean             @default(false)
  version          Int                 @default(1)
  created_at       DateTime            @default(now())
  updated_at       DateTime            @default(now())
  framework_id     String?
  status           String              @default("active")
  linked_rule_refs String[]            @default([])
  parent_section   String?
  provision_type   String              @default("section")
  sub_sections     Json                @default("[]")
  legislation_id   String?
  comments         Comment[]
  complianceItems  ComplianceItem[]
  oldMappings      OldMapping[]
  framework        Framework?          @relation(fields: [framework_id], references: [id], onDelete: Cascade)
  legislation      Legislation?        @relation(fields: [legislation_id], references: [id], onDelete: Cascade)
  organization     Organization?       @relation(fields: [org_id], references: [id])
  edits            ProvisionEdit[]
  sourceOf         ProvisionRelation[] @relation("source")
  targetOf         ProvisionRelation[] @relation("target")
  stateData        StateData[]
  compliances      EntityCompliance[]
  diligenceItems   DiligenceRequisition[]
}

model OldMapping {
  id                 String    @id @default(cuid())
  provision_id       String
  act_name           String
  section            String
  summary            String
  full_text          String
  change_description String
  change_tags        String[]
  sub_section        String?
  target_sub_section String?
  provision          Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model ComplianceItem {
  id           String    @id @default(cuid())
  provision_id String
  task         String
  assignee     String?
  status       String    @default("Not Started")
  due_date     DateTime?
  completed_at DateTime?
  provision    Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model StateData {
  id                String    @id @default(cuid())
  provision_id      String
  state             String
  notes             String?
  rule_text         String?
  compliance_status String?
  provision         Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model ProvisionEdit {
  id           String    @id @default(cuid())
  provision_id String
  user_id      String
  diff         Json
  edit_type    String
  created_at   DateTime  @default(now())
  provision    Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id])
}

model Comment {
  id           String    @id @default(cuid())
  provision_id String
  user_id      String
  body         String
  parent_id    String?
  created_at   DateTime  @default(now())
  parent       Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies      Comment[] @relation("CommentReplies")
  provision    Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id])
}

model Legislation {
  id           String      @id @default(cuid())
  framework_id String
  name         String
  short_name   String
  type         String      @default("act")
  is_repealed  Boolean     @default(false)
  year         Int?
  color        String?
  created_at   DateTime    @default(now())
  framework    Framework   @relation(fields: [framework_id], references: [id], onDelete: Cascade)
  provisions   Provision[]
}

model ProvisionRelation {
  id            String    @id @default(cuid())
  source_id     String
  target_id     String
  relation_type String
  notes         String?
  created_at    DateTime  @default(now())
  source        Provision @relation("source", fields: [source_id], references: [id], onDelete: Cascade)
  target        Provision @relation("target", fields: [target_id], references: [id], onDelete: Cascade)

  @@unique([source_id, target_id, relation_type])
}

model Framework {
  id           String        @id @default(cuid())
  name         String
  description  String?
  org_id       String?
  created_at   DateTime      @default(now())
  short_name   String?
  legislations Legislation[]
  provisions   Provision[]
}

model Entity {
  id                 String                @id @default(cuid())
  org_id             String?
  name               String
  type               String?
  incorporation_date DateTime?
  industry           String?
  status             String                @default("Healthy")
  health_score       Int                   @default(100)
  compliance_score   String                @default("A")
  last_audit_at      DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt
  agreements         AgreementInstance[]
  businessContracts  BusinessContract[]
  capTable           CapTableEntry[]
  ClientAccess       ClientAccess[]
  hygieneLogs        CorporateHygieneLog[]
  compliances        EntityCompliance[]
  licenses           License[]
  matters            Matter[]
}

model EntityCompliance {
  id              String    @id @default(cuid())
  entity_id       String
  provision_id    String
  applicability   String    @default("Applicable")
  status          String    @default("Not Started")
  next_audit_date DateTime?
  notes           String?
  entity          Entity    @relation(fields: [entity_id], references: [id], onDelete: Cascade)
  provision       Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model AgreementTemplate {
  id         String              @id @default(cuid())
  name       String
  category   String
  content    String
  created_at DateTime            @default(now())
  instances  AgreementInstance[]
  variables  AgreementVariable[]
}

model AgreementVariable {
  id          String            @id @default(cuid())
  template_id String
  key         String
  label       String
  type        String            @default("text")
  template    AgreementTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model AgreementInstance {
  id               String            @id @default(cuid())
  template_id      String
  company_id       String?
  name             String
  filled_variables Json
  status           String            @default("Draft")
  created_at       DateTime          @default(now())
  entity           Entity?           @relation(fields: [company_id], references: [id])
  template         AgreementTemplate @relation(fields: [template_id], references: [id])
}

model CapTableEntry {
  id               String   @id @default(cuid())
  company_id       String
  round_name       String
  date             DateTime
  pre_money_val    Float?
  post_money_val   Float?
  shares_issued    Int
  price_per_share  Float?
  investor_name    String
  compliance_check Boolean  @default(false)
  notes            String?
  entity           Entity   @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model CorporateHygieneLog {
  id                String    @id @default(cuid())
  company_id        String
  event_type        String
  due_date          DateTime?
  completed_date    DateTime?
  status            String    @default("Pending")
  potential_penalty Float?
  notes             String?
  entity            Entity    @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model License {
  id          String    @id @default(cuid())
  company_id  String
  name        String
  issuer      String
  issue_date  DateTime?
  expiry_date DateTime?
  status      String    @default("Active")
  entity      Entity    @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model BusinessContract {
  id              String    @id @default(cuid())
  company_id      String
  counterparty    String
  contract_type   String
  effective_date  DateTime?
  expiry_date     DateTime?
  value           Float?
  key_obligations String?
  entity          Entity    @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model WorkflowTemplate {
  id          String          @id @default(cuid())
  name        String
  description String?
  version     Int             @default(1)
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  stages      WorkflowStage[]
  workspaces  Workspace[]
}

model WorkflowStage {
  id          String           @id @default(cuid())
  template_id String
  name        String
  order       Int
  tasks       TaskMaster[]
  template    WorkflowTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model TaskMaster {
  id          String         @id @default(cuid())
  stage_id    String
  title       String
  description String?
  is_required Boolean        @default(true)
  order       Int
  instances   TaskInstance[]
  stage       WorkflowStage  @relation(fields: [stage_id], references: [id], onDelete: Cascade)
}

model Workspace {
  id          String           @id @default(cuid())
  template_id String
  org_id      String?
  title       String
  status      String           @default("Active")
  target_date DateTime?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  tasks       TaskInstance[]
  template    WorkflowTemplate @relation(fields: [template_id], references: [id])
}

model TaskInstance {
  id           String     @id @default(cuid())
  workspace_id String
  master_id    String
  title        String
  status       String     @default("Todo")
  assignee_id  String?
  notes        String?
  due_date     DateTime?
  completed_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  assignee     User?      @relation(fields: [assignee_id], references: [id])
  master       TaskMaster @relation(fields: [master_id], references: [id])
  workspace    Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
}

model Act {
  id          String       @id @default(cuid())
  name        String
  description String?
  enacted_at  DateTime?
  sections    ActSection[]
}

model ActSection {
  id          String                 @id @default(cuid())
  act_id      String
  number      String
  title       String
  content     String
  act         Act                    @relation(fields: [act_id], references: [id], onDelete: Cascade)
  obligations ComplianceObligation[]
}

model ComplianceObligation {
  id                String         @id @default(cuid())
  section_id        String
  title             String
  description       String
  trigger_event     String?
  applicable_entity String?
  authority         String?
  required_form     String?
  filing_timeline   String?
  penalty_desc      String?
  section           ActSection     @relation(fields: [section_id], references: [id], onDelete: Cascade)
  scenario_rules    ScenarioRule[]
  task_templates    TaskTemplate[]
}

model ScenarioTemplate {
  id          String         @id @default(cuid())
  name        String
  description String?
  matters     Matter[]
  rules       ScenarioRule[]
}

model ScenarioRule {
  id            String               @id @default(cuid())
  scenario_id   String
  obligation_id String
  obligation    ComplianceObligation @relation(fields: [obligation_id], references: [id], onDelete: Cascade)
  scenario      ScenarioTemplate     @relation(fields: [scenario_id], references: [id], onDelete: Cascade)

  @@unique([scenario_id, obligation_id])
}

model Matter {
  id             String            @id @default(cuid())
  name           String
  description    String?
  scenario_id    String?
  status         String            @default("Active")
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  org_id         String?
  client_id      String?
  clientAccesses ClientAccess[]
  entity         Entity?           @relation(fields: [client_id], references: [id])
  organization   Organization?     @relation(fields: [org_id], references: [id])
  scenario       ScenarioTemplate? @relation(fields: [scenario_id], references: [id])
  documents      MatterDocument[]
  members        MatterMember[]
  tasks          Task[]
  cases          LegalCase[]
  auditLogs      AuditLog[]
  diligence      DiligenceProject?
}

model AuditLog {
  id           String        @id @default(cuid())
  org_id       String?
  actor_id     String?
  action       String
  entity_type  String
  entity_id    String?
  metadata     Json?         @default("{}")
  ip_address   String?
  created_at   DateTime      @default(now())
  matter_id    String?
  organization Organization? @relation(fields: [org_id], references: [id])
  matter       Matter?       @relation(fields: [matter_id], references: [id])
}

model MatterMember {
  id        String @id @default(cuid())
  matter_id String
  user_id   String
  role      String
  matter    Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([matter_id, user_id])
}

model TaskTemplate {
  id            String                @id @default(cuid())
  obligation_id String?
  name          String
  description   String?
  stage         String                @default("Structuring")
  obligation    ComplianceObligation? @relation(fields: [obligation_id], references: [id])
}

model Task {
  id            String           @id @default(cuid())
  matter_id     String
  name          String
  description   String?
  stage         String           @default("Structuring")
  status        String           @default("To Do")
  due_date      DateTime?
  assignee_id   String?
  dependency_id String?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  documents     MatterDocument[]
  assignee      User?            @relation(fields: [assignee_id], references: [id])
  dependency    Task?            @relation("TaskDependencies", fields: [dependency_id], references: [id])
  dependents    Task[]           @relation("TaskDependencies")
  matter        Matter           @relation(fields: [matter_id], references: [id], onDelete: Cascade)
}

model MatterDocument {
  id          String   @id @default(cuid())
  matter_id   String
  task_id     String?
  name        String
  file_url    String
  uploaded_at DateTime @default(now())
  matter      Matter   @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [task_id], references: [id])
}

model RawScrapeData {
  id          String          @id @default(cuid())
  source_url  String
  source_name String
  raw_html    String
  raw_text    String
  scraped_at  DateTime        @default(now())
  processed   Boolean         @default(false)
  drafts      DraftScenario[]
}

model DraftScenario {
  id            String         @id @default(cuid())
  raw_scrape_id String?
  name          String
  description   String?
  category      String
  trigger_event String?
  status        String         @default("Pending Review")
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  raw_scrape    RawScrapeData? @relation(fields: [raw_scrape_id], references: [id])
  tasks         DraftTask[]
}

model DraftTask {
  id                String        @id @default(cuid())
  draft_scenario_id String
  name              String
  description       String?
  stage             String        @default("Structuring")
  priority          String        @default("Medium")
  due_logic         String?
  draft_scenario    DraftScenario @relation(fields: [draft_scenario_id], references: [id], onDelete: Cascade)
}
model LegalCase {
  id           String    @id @default(cuid())
  matter_id    String?
  name         String
  case_number  String?
  court        String?
  bench        String?
  status       String    @default("Active") // Active, Stayed, Disposed, Appeal
  stage        String    @default("Notice") // Notice, Pleadings, Evidence, Arguments, Judgment
  exposure_amount Float?
  currency        String?   @default("INR")
  description  String?
  opposition   String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  matter       Matter?   @relation(fields: [matter_id], references: [id])
  hearings     Hearing[]
  counsels     Counsel[]
}
model Counsel {
  id             String      @id @default(cuid())
  name           String
  representative_name String?
  firm           String?
  specialization String?
  email          String?
  phone          String?
  rating         Float       @default(0.0)
  hourly_rate    Float?
  status         String      @default("Active")
  cases          LegalCase[]
  created_at     DateTime    @default(now())
  updated_at     DateTime    @default(now())
}

model Hearing {
  id           String    @id @default(cuid())
  case_id      String
  date         DateTime
  description  String?
  orders_passed String?
  next_date    DateTime?
  status       String    @default("Scheduled") // Scheduled, adjourned, Heard
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())
  case         LegalCase @relation(fields: [case_id], references: [id], onDelete: Cascade)
}
model DiligenceProject {
  id              String                @id @default(cuid())
  matter_id       String                @unique
  name            String
  client_name     String
  target_company  String
  type            String // VC, PE, M&A, etc.
  jurisdiction    String?
  status          String                @default("Setup")
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt
  matter          Matter                @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  buckets         DiligenceBucket[]
  requisitions    DiligenceRequisition[]
}

model DiligenceMatrix {
  id             String               @id @default(cuid())
  requisition_id String               @unique
  columns        Json                 @default("[]") // [{ key: "entity_name", label: "Entity Name", type: "text" }, ...]
  requisition    DiligenceRequisition @relation(fields: [requisition_id], references: [id], onDelete: Cascade)
  rows           DiligenceMatrixRow[]
}

model DiligenceMatrixRow {
  id        String                @id @default(cuid())
  matrix_id String
  data      Json                  @default("{}") // { "entity_name": "Shareholder A", "status": "Verified" }
  matrix    DiligenceMatrix       @relation(fields: [matrix_id], references: [id], onDelete: Cascade)
  cells     DiligenceMatrixCell[]
}

model DiligenceMatrixCell {
  id             String             @id @default(cuid())
  row_id         String
  column_key     String
  comment        String?
  document_id    String?
  row            DiligenceMatrixRow @relation(fields: [row_id], references: [id], onDelete: Cascade)
  document       DiligenceDocument? @relation(fields: [document_id], references: [id])
  
  @@unique([row_id, column_key])
}

model DiligenceBucket {
  id          String                 @id @default(cuid())
  project_id  String
  name        String
  project     DiligenceProject       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  items       DiligenceRequisition[]
}

model DiligenceRequisition {
  id               String               @id @default(cuid())
  project_id       String
  bucket_id        String?
  title            String
  description      String?
  legal_relevance  String?
  entity_type      String? // Private, Public, LLP, Startup
  applicable_law   String?
  required_docs    String?
  risk_flag        Boolean              @default(false)
  status           String               @default("Requested") // Requested, Received, Under Review, Complete
  notes            String?
  provision_id     String? // Link to Knowledge Library
  project          DiligenceProject     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  bucket           DiligenceBucket?     @relation(fields: [bucket_id], references: [id])
  provision        Provision?           @relation(fields: [provision_id], references: [id])
  documents        DiligenceDocument[]
  findings         DiligenceFinding[]
  matrix           DiligenceMatrix?
}

model DiligenceDocument {
  id             String               @id @default(cuid())
  requisition_id String
  name           String
  url            String
  version        Int                  @default(1)
  notes          String?
  uploaded_at    DateTime             @default(now())
  requisition    DiligenceRequisition @relation(fields: [requisition_id], references: [id], onDelete: Cascade)
  matrixCells    DiligenceMatrixCell[]
}

model DiligenceFinding {
  id             String               @id @default(cuid())
  requisition_id String
  severity       String               @default("No Issue") // No Issue, Minor, Moderate, High, Deal Breaker
  description    String
  analysis       String?
  recommendation String?
  created_at     DateTime             @default(now())
  requisition    DiligenceRequisition @relation(fields: [requisition_id], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// Document Hub — Vectorless RAG & AI Suggestions
// ──────────────────────────────────────────────

model Document {
  id          String               @id @default(cuid())
  name        String
  file_name   String
  file_size   Int
  page_count  Int                  @default(0)
  raw_text    String?              @db.Text
  status      String               @default("uploaded") // uploaded | analyzing | analyzed | error
  uploaded_at DateTime             @default(now())
  analyzed_at DateTime?
  uploaded_by String?
  user        User?                @relation(fields: [uploaded_by], references: [id])
  analyses    DocumentAnalysis[]
  suggestions DocumentSuggestion[]

  @@index([status])
  @@index([name])
  @@index([file_name])
}

model DocumentAnalysis {
  id                  String               @id @default(cuid())
  document_id         String
  document            Document             @relation(fields: [document_id], references: [id], onDelete: Cascade)
  summary             String?              @db.Text
  document_type       String?
  structured_data     Json?
  graph_nodes         Int                  @default(0)
  graph_relationships Int                  @default(0)
  created_at          DateTime             @default(now())
  suggestions         DocumentSuggestion[]
}

model DocumentSuggestion {
  id               String            @id @default(cuid())
  document_id      String
  document         Document          @relation(fields: [document_id], references: [id], onDelete: Cascade)
  legal_doc_id     String?
  legal_document   LegalDocument?    @relation(fields: [legal_doc_id], references: [id])
  analysis_id      String?
  analysis         DocumentAnalysis? @relation(fields: [analysis_id], references: [id])
  type             String            // create_legislation | create_provision | create_compliance_item | create_penalty | flag_repeal
  target_module    String            // knowledge_base | compliance_tracker
  suggested_data   Json
  confidence       Float             @default(0.0)
  status           String            @default("pending") // pending | approved | rejected | edited
  reviewed_by      String?
  reviewed_at      DateTime?
  rejection_reason String?
  created_at       DateTime          @default(now())
}

// Blockchain-style tamper-proof audit chain
model AuditChain {
  id            String   @id @default(cuid())
  action        String
  entity_type   String
  entity_id     String
  data_snapshot String?  @db.Text
  previous_hash String
  current_hash  String   @unique
  performed_by  String?
  created_at    DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([created_at])
}

// --- New Pipeline Models ---

model LegalDocument {
  id                    String           @id @default(cuid())
  title                 String
  short_title           String?
  year                  Int?
  jurisdiction          String           // Central | State
  primary_state         String?          // If type=State
  appropriate_govt      String?          // Appropriate Government Level
  doc_type              String           // Act | Rule | Notification | Code
  is_connector_act      Boolean          @default(false)
  auto_apply_amendments Boolean          @default(true)
  full_text             String?          @db.Text
  summary               String?          @db.Text
  source_url            String?
  source_doc_id         String?          // Original Source Document (if applicable)
  processing_job_id     String?          // Job that created it
  status                String           @default("active") // active | repealed | draft
  uploaded_at           DateTime         @default(now())
  analyzed_at           DateTime?
  units                 StructuralUnit[]
  suggestions           DocumentSuggestion[]
  NotificationRecord    NotificationRecord[]
}

model StructuralUnit {
  id                     String                  @id @default(cuid())
  legal_doc_id           String
  legal_document         LegalDocument           @relation(fields: [legal_doc_id], references: [id], onDelete: Cascade)
  parent_unit_id         String?                 // Hierarchy
  parent_unit            StructuralUnit?         @relation("SubUnits", fields: [parent_unit_id], references: [id], onDelete: SetNull)
  child_units            StructuralUnit[]        @relation("SubUnits")
  unit_type              String                  // Chapter | Section | SubSection | Clause
  unit_number            String
  title                  String?
  summary                String?                 @db.Text
  full_text              String?                 @db.Text
  sort_order             Int
  provision_nature       String?                 // Obligatory | Prohibitory | Advisory
  status                 String                  @default("active")
  confidence_score       Float                   @default(1.0)
  definitions            LegalDefinition[]
  obligations            ObligationRecord[]
  penalties              PenaltyRecord[]
  xrefs                  CrossReference[]
  applicability          ApplicabilityCondition?
  rights                 RightsAndRemedy[]
}

model LegalDefinition {
  id               String         @id @default(cuid())
  unit_id          String
  unit             StructuralUnit @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  legal_doc_id     String?
  term             String
  definition_text  String         @db.Text
  definition_type  String         @default("standard")
  section_ref      String?
  context          String?
}

model ObligationRecord {
  id                  String         @id @default(cuid())
  unit_id             String
  unit                StructuralUnit @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  task                String?        @db.Text // Legacy
  title               String?
  description         String?        @db.Text
  obligation_type     String         @default("compliance")
  compliance_category String         @default("ongoing")
  actor               String?        // Employer | Occupier | Manager
  responsible_person  String?
  trigger_event       String?
  due_date_rule       String?
  prescribed_form     String?
  prescribed_authority String?
  frequency           String?        // Once | Monthly | Annual | Event-based
  due_logic           String?        @db.Text
  status              String         @default("active")
  created_at          DateTime       @default(now())
}

model PenaltyRecord {
  id               String         @id @default(cuid())
  unit_id          String
  unit             StructuralUnit @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  obligation_id    String?
  imprisonment     String?
  fine_amount      String?        // Code expects this
  fine_min         Float?
  fine_max         Float?
  fine_currency    String         @default("INR")
  liable_person    String?
  description      String?        @db.Text
}

model CrossReference {
  id                  String         @id @default(cuid())
  source_doc_id       String?
  source_unit_id      String
  source_unit         StructuralUnit @relation(fields: [source_unit_id], references: [id], onDelete: Cascade)
  target_doc_id       String?
  target_doc_name     String?
  target_unit_id      String?
  target_unit_number  String?
  target_section_ref  String?
  target_act_name     String?
  reference_type      String         @default("intra_doc") // intra_doc | inter_doc | unresolved
  reference_subtype   String?
  ref_type            String         @default("other")
  raw_text            String?
  is_resolved         Boolean        @default(false)
  is_verified         Boolean        @default(false)
}

model ApplicabilityCondition {
  id               String         @id @default(cuid())
  unit_id          String         @unique
  unit             StructuralUnit @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  condition_type   String         // entity_type | threshold | exemption
  entity_types     String?        // JSON list
  thresholds       String?        // JSON map
  exemptions       String?        // JSON list
  description      String?        @db.Text
}

model LegalAuthority {
  id               String          @id @default(cuid())
  name             String          @unique
  jurisdiction     String
  authority_type   String          @default("other")
  powers           String?         @db.Text
  links            AuthorityLink[]
}

model AuthorityLink {
  id               String         @id @default(cuid())
  authority_id     String
  authority        LegalAuthority @relation(fields: [authority_id], references: [id], onDelete: Cascade)
  unit_id          String?
  related_unit_id  String
  role             String?
}

model RightsAndRemedy {
  id                String         @id @default(cuid())
  unit_id           String
  unit              StructuralUnit @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  right_holder      String
  summary           String         @db.Text
  procedure         String?        @db.Text
  forum_level       String?
  forum_name        String?
  limitation_period String?
}

model ProcessingJob {
  id               String    @id @default(cuid())
  document_id      String?   @unique
  status           String    @default("pending") // pending | processing | completed | failed
  current_stage    String?
  current_pass     Int       @default(0)
  total_passes     Int       @default(6)
  progress         Float     @default(0)
  error_log        String?   @db.Text
  result_doc_id    String?   // points to the LegalDocument created
  started_at       DateTime  @default(now())
  completed_at     DateTime?
}

model NotificationRecord {
  id               String        @id @default(cuid())
  doc_id           String
  document         LegalDocument @relation(fields: [doc_id], references: [id], onDelete: Cascade)
  title            String
  summary          String        @db.Text
  published_at     DateTime
  source_url       String?
}
