generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js essential models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("viewer") // custom role: admin, editor, reviewer, viewer
  accounts      Account[]
  sessions      Session[]

  // Custom domains
  provisionEdits ProvisionEdit[]
  comments       Comment[]

  last_login   DateTime?
  TaskInstance TaskInstance[]

  // Legal OS Relations
  matterMembers     MatterMember[]
  assignedTasks     Task[]
  clientAccesses    ClientAccess[]
  organizationUsers OrganizationUser[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom app tables
model Organization {
  id         String   @id @default(cuid())
  name       String
  plan       String   @default("Free")
  settings   Json?
  created_at DateTime @default(now())

  provisions   Provision[]
  subscription Subscription?
  users        OrganizationUser[]
  matters      Matter[]
}

model OrganizationUser {
  id      String @id @default(cuid())
  org_id  String
  user_id String
  role    String @default("Member") // Admin, Member, Guest

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Subscription {
  id                 String    @id @default(cuid())
  org_id             String    @unique
  stripe_cust_id     String?
  plan_tier          String    @default("Free")
  status             String    @default("Active")
  current_period_end DateTime?

  organization Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
}

model ClientAccess {
  id         String  @id @default(cuid())
  user_id    String // The external client user
  matter_id  String? // Granted access to specific matters
  company_id String? // Granted access to specific entity hygiene
  role       String  @default("ClientViewer")

  user    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  matter  Matter?  @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  entity  Entity?  @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

model Provision {
  id               String    @id @default(cuid())
  org_id           String?
  framework_id     String?
  legislation_id   String?   // New: Reference to specific legislation tile
  code             String
  chapter          String
  chapter_name     String
  section          String
  sub_section      String
  title            String
  provision_type   String    @default("section") // section | rule | form | register
  parent_section   String?   // For rules: which section this rule implements
  sub_sections     Json      @default("[]")      // SubSection[] as JSON
  linked_rule_refs String[]  @default([])        // For sections: rule refs that implement this
  summary          String
  full_text        String    @db.Text
  impact           String
  rule_authority   String
  change_tags      String[]
  workflow_tags    String[]
  penalty_old      String?
  penalty_new      String?
  notes            String?
  assignee         String?
  due_date         DateTime?
  verified         Boolean   @default(false)
  pinned           Boolean   @default(false)
  version          Int       @default(1)
  status           String    @default("active") // active, revoked, amended
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now())

  // Relations
  organization    Organization?    @relation(fields: [org_id], references: [id])
  framework       Framework?       @relation(fields: [framework_id], references: [id])
  legislation     Legislation?     @relation(fields: [legislation_id], references: [id])
  oldMappings     OldMapping[]
  complianceItems ComplianceItem[]
  stateData       StateData[]
  edits           ProvisionEdit[]
  comments        Comment[]
  
  // Connectors
  sourceOf        ProvisionRelation[] @relation("source")
  targetOf        ProvisionRelation[] @relation("target")
}

model OldMapping {
  id                 String   @id @default(cuid())
  provision_id       String
  act_name           String
  section            String
  sub_section        String?
  target_sub_section String?
  summary            String
  full_text          String   @db.Text
  change_description String
  change_tags        String[]

  provision Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model ComplianceItem {
  id           String    @id @default(cuid())
  provision_id String
  task         String
  assignee     String?
  status       String    @default("Not Started")
  due_date     DateTime?
  completed_at DateTime?

  provision Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model StateData {
  id                String  @id @default(cuid())
  provision_id      String
  state             String
  notes             String?
  rule_text         String? @db.Text
  compliance_status String?

  provision Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
}

model ProvisionEdit {
  id           String   @id @default(cuid())
  provision_id String
  user_id      String
  diff         Json
  edit_type    String
  created_at   DateTime @default(now())

  provision Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id])
}

model Comment {
  id           String   @id @default(cuid())
  provision_id String
  user_id      String
  body         String   @db.Text
  parent_id    String?
  created_at   DateTime @default(now())

  provision Provision @relation(fields: [provision_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id])
  parent    Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies   Comment[] @relation("CommentReplies")
}

// ==============================================================================
// 🌟 4-PRODUCT LEGAL OS EXPANSION SCHEMAS
// ==============================================================================

// ---------------------------------------------------------
// PRODUCT 1: Universal Provision Mapping Tool
// ---------------------------------------------------------
model Legislation {
  id           String    @id @default(cuid())
  framework_id String
  name         String    // e.g., "Payment of Wages Act, 1936"
  short_name   String    // e.g., "PWA36"
  type         String    @default("act") // act | rules | repealed_act | repealed_rules
  is_repealed  Boolean   @default(false)
  year         Int?
  color        String?
  created_at   DateTime  @default(now())
  
  framework    Framework @relation(fields: [framework_id], references: [id], onDelete: Cascade)
  provisions   Provision[]
}

model ProvisionRelation {
  id            String   @id @default(cuid())
  source_id     String
  target_id     String
  relation_type String   // IMPLEMENTS | PRESCRIBES | REPLACES | REFERENCES
  notes         String?
  created_at    DateTime @default(now())

  source        Provision @relation("source", fields: [source_id], references: [id], onDelete: Cascade)
  target        Provision @relation("target", fields: [target_id], references: [id], onDelete: Cascade)

  @@unique([source_id, target_id, relation_type])
}

model Framework {
  id          String   @id @default(cuid())
  name        String // e.g., "Labour Codes", "Companies Act", "FEMA"
  short_name  String?
  description String?  @db.Text
  org_id      String?
  created_at  DateTime @default(now())

  legislations Legislation[]
  provisions   Provision[]
}

// ---------------------------------------------------------
// PRODUCT 2: Entity Compliance Tracker
// ---------------------------------------------------------
model Entity {
  id                 String    @id @default(cuid())
  org_id             String?
  name               String
  type               String?   // e.g., "Public Listed", "LLP", "Private Limited"
  incorporation_date DateTime?
  industry           String?
  status             String    @default("Healthy") // Healthy, Warning, Critical
  health_score       Int       @default(100)
  compliance_score   String    @default("A")
  last_audit_at      DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  // Relations to other products
  compliances       EntityCompliance[]
  agreements        AgreementInstance[]
  capTable          CapTableEntry[]
  hygieneLogs       CorporateHygieneLog[]
  licenses          License[]
  businessContracts BusinessContract[]
  ClientAccess      ClientAccess[]
  matters           Matter[]
}

model EntityCompliance {
  id              String    @id @default(cuid())
  entity_id       String
  provision_id    String // The specific law this entity must comply with
  applicability   String    @default("Applicable") // Applicable, Not Applicable, Exempt
  status          String    @default("Not Started") // Compliant, At Risk, Non-Compliant
  next_audit_date DateTime?
  notes           String?   @db.Text

  entity Entity @relation(fields: [entity_id], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------
// PRODUCT 3: Modular Agreement Drafting Platform
// ---------------------------------------------------------
model AgreementTemplate {
  id         String   @id @default(cuid())
  name       String // e.g., "Non-Disclosure Agreement", "Employment Contract"
  category   String
  content    String   @db.Text // The raw HTML/Markdown template containing {{variables}}
  created_at DateTime @default(now())

  variables AgreementVariable[]
  instances AgreementInstance[]
}

model AgreementVariable {
  id          String @id @default(cuid())
  template_id String
  key         String // e.g., "Company_Name"
  label       String // e.g., "What is the name of the hiring company?"
  type        String @default("text") // text, date, number, currency

  template AgreementTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
}

model AgreementInstance {
  id               String   @id @default(cuid())
  template_id      String
  company_id       String?
  name             String // e.g., "NDA - Reliance Ind."
  filled_variables Json // Key-value store of filled variables mapping to the template
  status           String   @default("Draft") // Draft, Ready for Signature, Signed
  created_at       DateTime @default(now())

  template AgreementTemplate @relation(fields: [template_id], references: [id])
  entity   Entity?           @relation(fields: [company_id], references: [id])
}

// ---------------------------------------------------------
// PRODUCT 4: Intelligent Due Diligence Checklist
// ---------------------------------------------------------

// Window 1: Capital Structure & Valuation
model CapTableEntry {
  id               String   @id @default(cuid())
  company_id       String
  round_name       String // e.g., "Seed", "Series A"
  date             DateTime
  pre_money_val    Float?
  post_money_val   Float?
  shares_issued    Int
  price_per_share  Float?
  investor_name    String
  compliance_check Boolean  @default(false) // Did this issuance comply with Companies Act Section 42/62?
  notes            String?

  entity Entity @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

// Window 3: Corporate Hygiene & Penalty Monitor
model CorporateHygieneLog {
  id                String    @id @default(cuid())
  company_id        String
  event_type        String // e.g., "Board Meeting", "AGM", "AOC-4 Filing"
  due_date          DateTime?
  completed_date    DateTime?
  status            String    @default("Pending") // Compliant, Delayed, Defaulted
  potential_penalty Float? // Calculated fine if delayed
  notes             String?

  entity Entity @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

// Window 4: Licenses & Authorizations
model License {
  id          String    @id @default(cuid())
  company_id  String
  name        String // e.g., "Factory License", "Shop & Establishment"
  issuer      String // e.g., "State Labor Department"
  issue_date  DateTime?
  expiry_date DateTime?
  status      String    @default("Active") // Active, Expired, Revoked, Applied

  entity Entity @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

// Window 5: Business Contracts Repository
model BusinessContract {
  id              String    @id @default(cuid())
  company_id      String
  counterparty    String
  contract_type   String // e.g., "Vendor", "Client MSA", "IP Assignment"
  effective_date  DateTime?
  expiry_date     DateTime?
  value           Float?
  key_obligations String?   @db.Text

  entity Entity @relation(fields: [company_id], references: [id], onDelete: Cascade)
}

// ==============================================================================
// 🌟 PHASE 5: TWO-LAYER WORKFLOW & TASK EXECUTION ENGINE
// ==============================================================================

// ---------------------------------------------------------
// LAYER 2: WORKFLOW TEMPLATES (The Master Blueprint)
// ---------------------------------------------------------
model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String // e.g., "13-Stage VC/PE Deal Execution"
  description String?  @db.Text
  version     Int      @default(1)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  stages     WorkflowStage[]
  workspaces Workspace[]
}

model WorkflowStage {
  id          String @id @default(cuid())
  template_id String
  name        String // e.g., "1. Deal Origination & Pre-Investment Structuring"
  order       Int // 1, 2, 3... to maintain the 13-stage sequence

  template WorkflowTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  tasks    TaskMaster[]
}

model TaskMaster {
  id          String  @id @default(cuid())
  stage_id    String
  title       String // e.g., "Structuring Cap Table Modeling"
  description String? @db.Text
  is_required Boolean @default(true)
  order       Int // Order within the specific stage

  stage     WorkflowStage  @relation(fields: [stage_id], references: [id], onDelete: Cascade)
  instances TaskInstance[]
}

// ---------------------------------------------------------
// LAYER 2: ACTIVE WORKSPACES (The Deal Rooms)
// ---------------------------------------------------------
model Workspace {
  id          String    @id @default(cuid())
  template_id String
  org_id      String?
  title       String // e.g., "Project Phoenix - Series A"
  status      String    @default("Active") // Active, On Hold, Closed, Cancelled
  target_date DateTime?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  template WorkflowTemplate @relation(fields: [template_id], references: [id])
  tasks    TaskInstance[]
}

model TaskInstance {
  id           String    @id @default(cuid())
  workspace_id String
  master_id    String // The blueprint task this was generated from
  title        String // Copied from master, but can be overridden
  status       String    @default("Todo") // Todo, In Progress, Review, Done
  assignee_id  String? // Optional relation to User
  notes        String?   @db.Text
  due_date     DateTime?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  workspace Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  master    TaskMaster @relation(fields: [master_id], references: [id])
  assignee  User?      @relation(fields: [assignee_id], references: [id])
}

// ==============================================================================
// 🌟 LEGAL OS PIVOT: NEW 4-LAYER ARCHITECTURE MODELS
// ==============================================================================

// ---------------------------------------------------------
// LAYER 1: KNOWLEDGE LIBRARY
// ---------------------------------------------------------
model Act {
  id          String       @id @default(cuid())
  name        String // e.g., "Code on Wages, 2019"
  description String?      @db.Text
  enacted_at  DateTime?
  sections    ActSection[]
}

model ActSection {
  id          String                 @id @default(cuid())
  act_id      String
  number      String // e.g., "S.18"
  title       String
  content     String                 @db.Text
  act         Act                    @relation(fields: [act_id], references: [id], onDelete: Cascade)
  obligations ComplianceObligation[]
}

model ComplianceObligation {
  id                String  @id @default(cuid())
  section_id        String
  title             String
  description       String  @db.Text
  trigger_event     String?
  applicable_entity String?
  authority         String?
  required_form     String?
  filing_timeline   String?
  penalty_desc      String?

  section        ActSection     @relation(fields: [section_id], references: [id], onDelete: Cascade)
  scenario_rules ScenarioRule[]
  task_templates TaskTemplate[]
}

// ---------------------------------------------------------
// LAYER 2: SCENARIO ENGINE
// ---------------------------------------------------------
model ScenarioTemplate {
  id          String         @id @default(cuid())
  name        String // e.g., "Private Placement", "Factory Setup"
  description String?        @db.Text
  rules       ScenarioRule[]
  matters     Matter[]
}

model ScenarioRule {
  id            String @id @default(cuid())
  scenario_id   String
  obligation_id String

  scenario   ScenarioTemplate     @relation(fields: [scenario_id], references: [id], onDelete: Cascade)
  obligation ComplianceObligation @relation(fields: [obligation_id], references: [id], onDelete: Cascade)

  @@unique([scenario_id, obligation_id])
}

// ---------------------------------------------------------
// LAYER 3 & 4: WORKFLOW ENGINE & COLLABORATION (MATTERS)
// ---------------------------------------------------------
model Matter {
  id          String   @id @default(cuid())
  org_id      String?
  name        String // e.g., "Reliance - Q3 Private Placement"
  description String?  @db.Text
  scenario_id String?
  client_id   String?
  status      String   @default("Active")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  organization   Organization?     @relation(fields: [org_id], references: [id])
  entity         Entity?           @relation(fields: [client_id], references: [id])
  scenario       ScenarioTemplate? @relation(fields: [scenario_id], references: [id])
  tasks          Task[]
  members        MatterMember[]
  documents      MatterDocument[]
  clientAccesses ClientAccess[]
}

model MatterMember {
  id        String @id @default(cuid())
  matter_id String
  user_id   String
  role      String // Partner, Associate, Paralegal, Client

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([matter_id, user_id])
}

model TaskTemplate {
  id            String  @id @default(cuid())
  obligation_id String?
  name          String
  description   String? @db.Text
  stage         String  @default("Structuring") // Structuring, Documentation, Approvals, Filings, Closing

  obligation ComplianceObligation? @relation(fields: [obligation_id], references: [id])
}

model Task {
  id            String    @id @default(cuid())
  matter_id     String
  name          String
  description   String?   @db.Text
  stage         String    @default("Structuring")
  status        String    @default("To Do") // To Do, In Progress, Under Review, Filed, Completed
  due_date      DateTime?
  assignee_id   String?
  dependency_id String? // ID of a task this depends on
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  matter     Matter           @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  assignee   User?            @relation(fields: [assignee_id], references: [id])
  dependency Task?            @relation("TaskDependencies", fields: [dependency_id], references: [id])
  dependents Task[]           @relation("TaskDependencies")
  documents  MatterDocument[]
}

model MatterDocument {
  id          String   @id @default(cuid())
  matter_id   String
  task_id     String?
  name        String
  file_url    String
  uploaded_at DateTime @default(now())

  matter Matter @relation(fields: [matter_id], references: [id], onDelete: Cascade)
  task   Task?  @relation(fields: [task_id], references: [id])
}

// ==========================================
// PHASE 6: TIER 1 KNOWLEDGE INGESTION PIPELINE
// ==========================================

model RawScrapeData {
  id           String   @id @default(cuid())
  source_url   String
  source_name  String   // e.g., "TaxGuru", "ClearTax"
  raw_html     String   @db.Text
  raw_text     String   @db.Text
  scraped_at   DateTime @default(now())
  processed    Boolean  @default(false)
  
  drafts       DraftScenario[]
}

model DraftScenario {
  id              String   @id @default(cuid())
  raw_scrape_id   String?
  name            String
  description     String?  @db.Text
  category        String   // e.g., "Compliance", "Filings"
  trigger_event   String?
  status          String   @default("Pending Review") // Pending Review, Approved, Rejected
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  raw_scrape      RawScrapeData?  @relation(fields: [raw_scrape_id], references: [id])
  tasks           DraftTask[]
}

model DraftTask {
  id                String   @id @default(cuid())
  draft_scenario_id String
  name              String
  description       String?  @db.Text
  stage             String   @default("Structuring")
  priority          String   @default("Medium")
  due_logic         String?  // Text description from AI (e.g., "Within 30 days of resolution")
  
  draft_scenario    DraftScenario @relation(fields: [draft_scenario_id], references: [id], onDelete: Cascade)
}
